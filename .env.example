# Copy this file to .env and fill in your keys.
# Everything works in a built-in MOCK mode without keys, so you can
# explore the whole flow first, then add keys to make it real.

# --- Language model (story / script / character / prompt reasoning) ---
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Image + video generation ---
# fal.ai key: https://fal.ai/dashboard/keys
FAL_KEY=

# fal model routes (override if you want different models)
FAL_IMAGE_MODEL=fal-ai/flux/dev
# Video model for shots (start-frame + prompt -> video). Set to your Seedance route.
FAL_VIDEO_MODEL=fal-ai/bytedance/seedance/v1/pro/image-to-video

# --- Server ---
PORT=4317
